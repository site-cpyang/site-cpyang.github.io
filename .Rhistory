library(tidyverse)
library(caret)
library(pROC)
pumpkins <- read.csv("https://raw.githubusercontent.com/anlane611/datasets/refs/heads/main/pumpkin.csv")
pumpkins <- pumpkins |>
mutate(Class_fac = factor(ifelse(Class=="Çerçevelik",1,0),
levels=c(0,1),
labels=c("Ürgüp Sivrisi","Çerçevelik")))
pumpmod <- glm(Class_fac ~ Major_Axis_Length+Solidity,
data=pumpkins,
family="binomial")
plot(pumpmod)
pumpmod_reduced <- pumpmod
pumpmod_full <- glm(factor(Class) ~ Area + Perimeter +
Major_Axis_Length + Solidity,
data=pumpkins,
family="binomial")
anova(pumpmod_reduced, pumpmod_full, test="Chisq")
nba_mod_norm <- glm(factor(Win) ~ Home + TeamPoints + FieldGoals. + Assists + Steals + Blocks + TotalRebounds + Turnovers, data = nba_cho_norm, family = "binomial")
print(modelsummary(nba_mod_norm,
fmt = fmt_significant(2),
shape = term ~ model + statistic,
statistic = c("std.error","conf.int","p.value"),
output = "markdown",
exponentiate = TRUE,
gof_map=NA))
probabilities <- predict(nba_mod_norm, type = "response")
predicted.classes <- ifelse(probabilities > 0.5, 1, 0)
confusion.matrix <- table(Predicted = predicted.classes, Actual = nba_cho_norm$Win)
print(confusion.matrix)
roc_obj <- roc(nba_cho_norm$Win, probabilities)
plot(roc_obj, col = "blue", main = "ROC Curve")
auc_value <- auc(roc_obj)
legend("bottomright", legend = paste("AUC =", round(auc_value, 3)), bty = "n")
print(paste("AUC:", round(auc_value, 3)))
accuracy <- sum(predicted.classes == nba_cho_norm$Win) / length(nba_cho_norm$Win)
print(paste("Accuracy:", round(accuracy, 3)))
