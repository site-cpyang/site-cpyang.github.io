probabilities <- predict(nba_mod_norm, type = "response")
predicted.classes <- ifelse(probabilities > 0.5, 1, 0)
confusion.matrix <- table(Predicted = predicted.classes, Actual = nba_cho_norm$Win)
cm_df <- as.data.frame(confusion.matrix)
colnames(cm_df) <- c("Predicted", "Actual", "Freq")
ggplot(data = cm_df, aes(x = Actual, y = Predicted)) +
geom_tile(aes(fill = Freq), color = "white") +
geom_text(aes(label = Freq), vjust = 1.5, color = "black") +
scale_fill_gradient(low = "white", high = "steelblue") +
theme_minimal() +
ggtitle("Confusion Matrix")
roc_obj <- roc(nba_cho_norm$Win, probabilities)
plot(roc_obj, col = "blue", main = "ROC Curve")
auc_value <- auc(roc_obj)
